# DVLA IDP — pre-live compose environment.
# Copy to `.env` on the server and fill with real values. NEVER commit the real .env.
#
# Generate secrets:
#   POSTGRES_PASSWORD : openssl rand -hex 24
#   JWT_SECRET        : openssl rand -hex 32
#   AUDIT_ENCRYPTION_KEY : openssl rand -hex 16   (= exactly 32 chars, required in prod)

# ---- PostgreSQL (internal only) ----
POSTGRES_USER=dvla
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dvla_idp

# Backend DB connection (points at the internal `postgres` service)
DATABASE_URL=postgresql://dvla:change-me@postgres:5432/dvla_idp?schema=public
DIRECT_URL=postgresql://dvla:change-me@postgres:5432/dvla_idp?schema=public

# ---- Backend app ----
JWT_SECRET=change-me-long-random
AUDIT_ENCRYPTION_KEY=change-me-exactly-32-characters!
FRONTEND_URL=https://dvla.3dt.com.gh

# ---- Email -> Mailpit (internal only; captures all outbound mail) ----
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=dvla
SMTP_PASS=dvla
SMTP_FROM="DVLA Ghana IDP <noreply@dvla.3dt.com.gh>"

# ---- Mailpit auto-relay (also deliver captured mail to real inboxes) ----
# Upstream SMTP Mailpit forwards every message through (MP_SMTP_RELAY_ALL=true).
# For Gmail, OVERRIDE_FROM must be the authenticated account or Gmail rejects it.
# NOTE: rotate this credential periodically; once rotated, update here only (not in git).
MAIL_RELAY_USERNAME=your-account@gmail.com
MAIL_RELAY_PASSWORD=your-16-char-app-password
MAIL_RELAY_OVERRIDE_FROM=your-account@gmail.com

# ---- Object storage (MinIO, internal only; console at files.dvla.3dt.com.gh) ----
# Generate secrets: openssl rand -hex 24
# Root creds are for the console/admin only.
MINIO_ROOT_USER=dvla-minio
MINIO_ROOT_PASSWORD=change-me-long-random
MINIO_BUCKET=dvla-uploads
# Scoped service account the BACKEND uses (least privilege: dvla-uploads bucket only).
# Create with: mc admin user add + a policy limited to arn:aws:s3:::dvla-uploads[/*]
MINIO_ACCESS_KEY=dvla-app
MINIO_SECRET_KEY=change-me-scoped-secret

# ---- Frontend build arg (baked into the client bundle at build time) ----
NEXT_PUBLIC_API_URL=https://api.dvla.3dt.com.gh/api
